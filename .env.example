# Copy to .env and fill in real values

# --- Data providers ---
TWELVE_DATA_API_KEY=your_key_here

# Failover providers (optional — system works without these)
# Alpha Vantage: https://www.alphavantage.co/support/#api-key (free: 25 req/day)
# Note: FX intraday requires premium plan on Alpha Vantage
ALPHA_VANTAGE_API_KEY=

# Finnhub: https://finnhub.io (free: 60 req/min, FX via OANDA)
FINNHUB_API_KEY=

# FRED (St. Louis Fed) — official macro series for the Macro engine:
# DXY proxy (DTWEXBGS), VIX (VIXCLS), yields (DGS10/DGS2). Free key:
# https://fred.stlouisfed.org/docs/api/api_key.html
# Optional — without it the keyless fredgraph.csv export is used.
FRED_API_KEY=

# Yahoo Finance: no key needed (used automatically as secondary failover)
# Provider failover order: Twelve Data → Yahoo Finance → Alpha Vantage → Finnhub

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- API Server security (REQUIRED in production) ---
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
API_SERVER_KEY=your_random_secret_here

# --- News Intelligence (fundamentals layer) ---
# JBlanked News API: https://www.jblanked.com/ (free registration)
# Provides: economic calendar, event history, ML predictions
# Fallback: Forex Factory public JSON (no key needed)
JBLANKED_API_KEY=
# Set to "development" to enable Swagger docs and skip auth requirement
ENV=production

# --- OANDA Paper/Live Trading ---
# Register free at https://www.oanda.com/
# Practice account = paper trading (no real money)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice   # "practice" or "live"

# --- AI explanation layer (ai/ai_analyzer.py, opt-in via config.yaml ai.enabled) ---
# Only the key matching config.yaml's `ai.provider` is required.
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Storage backend (required — Cloudflare D1, see cloudflare/README.md) ---
# decision_db.py / outcome_tracker.py / engine_tracker.py / experience_db.py /
# symbol_health.py / calibration.py all read and write through the Worker
# proxy in cloudflare/worker.js. Deploy that Worker first, then fill these
# in — there is no local SQLite fallback.
D1_WORKER_URL=
D1_PROXY_TOKEN=
